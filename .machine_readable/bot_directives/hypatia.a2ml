# SPDX-License-Identifier: MPL-2.0
# hypatia.a2ml — Hypatia scanner directives for Cliodynamics.jl.
# Net-new at the 2026-06-13 governance checkpoint per the estate
# bot_directives standard (hypatia / gitbot-fleet / git-private-farm trio).

[metadata]
name = "Cliodynamics.jl-hypatia"
project = "Cliodynamics.jl"
schema_version = "1.0"
repo = "Cliodynamics.jl"
last-updated = "2026-06-13"
owner = "hyperpolymath"

[scanner]
workflow = ".github/workflows/hypatia-scan.yml"
ignore-file = ".hypatia-ignore"   # ABSENT as of 2026-06-13; created on first real adjudication, each entry carrying a verified rationale

# ============================================================
# Pre-adjudicated finding classes.
#
# These are grounded in documented repo facts (.claude/CLAUDE.md); they
# are NOT live suppressions. When the scanner first raises one, materialise
# it into .hypatia-ignore with the EXACT rule-id from the scan output —
# do not invent rule-ids here.
# ============================================================

[[accepted-findings]]
class = "julia/unsafe-ffi"
path = "ffi/zig/**"
status = "justified"
reason = """
The Zig FFI layer (ffi/zig/) implements the Idris2 ABI, which necessarily
crosses language boundaries. Unsafe calls in this layer are structural, not
incidental. Do not raise as memory-safety defects; if a new unsafe call
appears OUTSIDE ffi/zig/ or src/abi/, that IS a finding.
"""

[[accepted-findings]]
class = "data/synthetic-csv"
path = "data/seshat_sample.csv"
status = "documented"
reason = """
data/seshat_sample.csv is documented as synthetic (.claude/CLAUDE.md
"Synthetic Seshat-format historical data"). It is not real personal or
sensitive data; no PII scanner findings apply. Real Seshat data is not
committed to this repo.
"""

# ============================================================
# Prohibited actions
# ============================================================

[prohibited-actions]
auto-delete-branches = false
auto-merge = false
modify-workflows = false        # CI hardening goes through review, not bot edits
escalation = "open an issue, do not spam PR comments"
